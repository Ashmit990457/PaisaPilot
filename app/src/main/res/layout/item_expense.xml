<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/iv_category_icon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@color/gradient_start"
            android:padding="10dp"
            android:src="@android:drawable/ic_menu_agenda"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Medium"
            app:tint="@color/primary_purple" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tv_expense_title"
            style="@style/TextAppearance.Material3.TitleMedium"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@+id/iv_expense_options"
            app:layout_constraintStart_toEndOf="@id/iv_category_icon"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="Grocery Shopping" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_expense_category"
            style="@style/Widget.Material3.Chip.Assist"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginTop="4dp"
            app:chipMinHeight="0dp"
            app:chipStrokeWidth="0dp"
            android:textSize="11sp"
            app:layout_constraintStart_toStartOf="@id/tv_expense_title"
            app:layout_constraintTop_toBottomOf="@id/tv_expense_title"
            tools:text="Food" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tv_expense_date"
            style="@style/TextAppearance.Material3.LabelSmall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:textColor="@color/text_muted"
            app:layout_constraintBottom_toBottomOf="@id/chip_expense_category"
            app:layout_constraintStart_toEndOf="@id/chip_expense_category"
            app:layout_constraintTop_toTopOf="@id/chip_expense_category"
            tools:text="12 Oct" />

        <ImageView
            android:id="@+id/iv_expense_options"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Options"
            android:padding="4dp"
            android:src="@android:drawable/ic_menu_more"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/text_muted" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tv_expense_amount"
            style="@style/TextAppearance.Material3.TitleMedium"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#E11D48"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="-₹1,250.00" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tv_payment_method"
            style="@style/TextAppearance.Material3.LabelSmall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:textColor="@color/text_muted"
            app:layout_constraintBottom_toBottomOf="@id/tv_expense_amount"
            app:layout_constraintEnd_toStartOf="@id/tv_expense_amount"
            app:layout_constraintTop_toTopOf="@id/tv_expense_amount"
            tools:text="Cash" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
